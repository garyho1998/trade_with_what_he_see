# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual envs
venv/
.venv/
env/

# Local market-data state — regenerable, not personal/PII but large
market_data/market.db
market_data/market.db-*
market_data/warm.log
market_data/logs/

# Caches from individual skills (legacy JSON cache dirs)
.config/forward-rdcf/cache/
.config/minervini-screener/cache/

# Secrets — NEVER commit these
.env
*.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# OS / pip
*.egg-info/
build/
dist/

# Generated test outputs
/tmp/
benchmark_*.json
eval_set*.json
